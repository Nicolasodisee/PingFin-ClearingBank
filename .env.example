# Server Configuratie
PORT=8080
NODE_ENV=development

# Docker Configuratie
MYSQL_DATABASE=Pingfin
MYSQL_ROOT_PASSWORD=secret
DOCKER_DB_PORT=3306

# Database Configuratie
DB_HOST=localhost
DB_USER=root
DB_PASS=secret
DB_NAME=Pingfin

# Beveiliging
# Verander dit in een lange, willekeurige string voor productie!
JWT_SECRET=secretkey

# Frontend URL (voor CORS)
FRONTEND_URL=http://127.0.0.1:5500